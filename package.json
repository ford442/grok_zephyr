{
  "name": "grok-zephyr",
  "version": "1.0.0",
  "description": "WebGPU-powered orbital simulation with 1M+ satellites",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:standalone": "vite build --mode standalone",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:visual": "playwright test",
    "test:visual:update": "UPDATE_BASELINES=1 playwright test",
    "deploy": "npm run build && echo 'Deploy to gh-pages: copy dist/ contents to gh-pages branch'"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^20.10.0",
    "@types/pixelmatch": "^5.2.6",
    "@vitest/ui": "^4.1.7",
    "@webgpu/types": "^0.1.69",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "satellite.js": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
